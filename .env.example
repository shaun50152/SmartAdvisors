# ── Backend ──────────────────────────────────────────────────
# No backend .env needed for local dev — database paths are auto-detected.
# If you want to override, copy this file to .env and fill in.

PORT=8000
DATABASE_URL=sqlite:///server/data/classes.db

# ── Frontend (client/.env) ────────────────────────────────────
# Create a file at client/.env with the following line.
# Ask the team lead for the actual Client ID, or create your own
# at https://console.cloud.google.com → APIs & Services → Credentials.
# Make sure http://localhost:5173 is in Authorized JavaScript Origins.

VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
